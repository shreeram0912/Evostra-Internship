	partition DimDate = calculated
		mode: import
		source =
				
				ADDCOLUMNS(
				    CALENDAR(
				        MIN(FactOrders[OrderDate]),
				        MAX(FactOrders[OrderDate])
				    ),
				    "Year", YEAR([Date]),
				    "Month Number", MONTH([Date]),
				    "Month", FORMAT([Date],"MMM"),
				    "Quarter", "Q" & FORMAT([Date],"Q"),
				    "Day", DAY([Date]),
				    "Weekday", FORMAT([Date],"dddd"))

	annotation PBI_Id = e91a704368534399a33c895ec788cdd5

